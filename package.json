{
  "name": "spicedb-vscode",
  "displayName": "SpiceDB VSCode",
  "description": "VSCode Extension for working with SpiceDB",
  "publisher": "authzed",
  "version": "1.2.0",
  "icon": "icons/authzed-icon-multi-128x128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/authzed/spicedb-vscode.git"
  },
  "engines": {
    "vscode": "^1.106.1"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cel",
        "aliases": [
          "CEL",
          "cel"
        ]
      },
      {
        "id": "spicedb-yaml",
        "aliases": [
          "SpiceDB YAML"
        ],
        "extensions": [
          ".zed.yaml"
        ],
        "filenamePatterns": [
          "*.zed.yaml"
        ]
      },
      {
        "id": "spicedb",
        "aliases": [
          "SpiceDB",
          "spicedb",
          "Authzed",
          "authzed"
        ],
        "extensions": [
          ".zed"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/authzed-icon-multi-128x128.png",
          "dark": "./icons/authzed-icon-multi-128x128.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "cel",
        "scopeName": "source.cel",
        "path": "./syntaxes/cel.tmGrammar.json"
      },
      {
        "language": "spicedb-yaml",
        "scopeName": "source.spicedb-yaml",
        "path": "./syntaxes/spicedb-yaml.tmGrammar.json",
        "embeddedLanguages": {
          "meta.embedded.block.spicedb": "spicedb"
        }
      },
      {
        "scopeName": "spicedb-yaml.injection",
        "path": "./syntaxes/spicedb-yaml-injection.tmGrammar.json",
        "injectTo": [
          "source.spicedb-yaml"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.spicedb": "spicedb"
        }
      },
      {
        "language": "spicedb",
        "scopeName": "source.spicedb",
        "path": "./syntaxes/spicedb.tmGrammar.json",
        "embeddedLanguages": {
          "meta.embedded.block.cel": "cel"
        }
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "check-watches",
          "title": "Check Watches",
          "icon": "./icons/authzed-icon-multi-128x128.png"
        }
      ]
    },
    "views": {
      "check-watches": [
        {
          "type": "webview",
          "id": "spicedb.checkWatchView",
          "name": "Check Watches"
        }
      ]
    },
    "commands": [
      {
        "command": "spicedb.addCheckWatch",
        "category": "Check Watches",
        "title": "Add Check Watch",
        "icon": "$(watch-expressions-add)"
      }
    ],
    "configuration": {
      "title": "SpiceDB",
      "properties": {
        "spicedb.binaryPath": {
          "type": "string",
          "description": "Absolute path to a custom SpiceDB binary. If empty, the extension will look for 'spicedb' on your PATH."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "spicedb.addCheckWatch",
          "group": "navigation",
          "when": "view == spicedb.checkWatchView"
        }
      ]
    },
    "configurationDefaults": {
      "files.associations": {
        "*.zed.yaml": "spicedb-yaml"
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:build": "pnpm vsce package -o spicedb.vsix --no-yarn",
    "vscode:prepublish": "pnpm run compile",
    "vscode:publish": "pnpm vsce publish --no-yarn",
    "compile": "sh ./build-panels.sh",
    "watch": "pnpm tsc -watch -p ./",
    "pretest": "pnpm run compile && yarn run lint",
    "test": "pnpm vscode-test",
    "lint": "pnpm oxlint",
    "lint:fix": "pnpm oxlint --fix",
    "format": "pnpm run oxfmt --check",
    "format:fix": "pnpm run oxfmtl"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.10.1",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.106.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@authzed/spicedb-parser-js": "^1.0.5",
    "@types/command-exists": "^1.2.3",
    "@types/parsimmon": "^1.10.9",
    "command-exists": "^1.2.9",
    "parsimmon": "^1.18.1",
    "semver": "^7.7.4",
    "vscode-languageclient": "^9.0.1"
  },
  "packageManager": "pnpm@11.1.1"
}
